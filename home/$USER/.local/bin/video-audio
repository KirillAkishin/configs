#!/bin/bash

#sudo zypper install ffmpeg lame

BLACK="\e[30m"
RED="\e[31m"
PURPLE="\e[32m"
BROWN="\e[33m"
LIME="\e[34m"
PINK="\e[35m"
BLUE="\e[36m"
WHITE="\e[37m"
DEFAULT="\e[38m"
ENDCOLOR="\e[0m"

usage() {
    echo -e "${PINK}Usage: $0 [OPTION] FILE"
    echo "Converts MP4 to MP3"
    echo "  -d directory  If it is not empty, the script saves the output in [DIR] (default: '')"
    echo "  -p prefix     NEW_NAME = [PREFIX] + OLD_NAME (default: '_')"
    echo "  -v verbose    Verbose mode (default: false)"
    echo "  -h help       Print this help message"
    echo -e "${ENDCOLOR}"
    exit 1
}


NARGS=$#
VERBOSE=false
PREFIX='_'
DIR=''
OUTEXT='mp3'
PARAMS=" -q:a 2 "

# 0) [Original] '-c:a copy'
# 1) [HighQual] '-b:a 320k'
# 2) [1stAudio] '-map 0:a:0'
# 3) [2ndAudio] '-map 0:a:1'
# 4) [NoVid & NoSub & 1stAudio] '-vn -sn -map 0:a:0 -c:a copy'

while getopts 'd:p:vh' opt; do
  case $opt in
    d)
      DIR=${OPTARG}
      NARGS=$((NARGS-2))
      ;;
    p)
      PREFIX=${OPTARG}
      NARGS=$((NARGS-2))
      ;;
    v)
      VERBOSE=true
      PARAMS=$PARAMS' -loglevel error '
      NARGS=$((NARGS-1))
      ;;
	h)
      usage
      ;;
    ?)
      usage
      ;;
  esac
done

if [ $NARGS -ne 1 ]; then
    usage
    exit 1
fi

INPUT=${@: -1}
FILENAME="${INPUT##*/}"
BASE="${FILENAME%.*}"
OUTPUT="$PREFIX${BASE%.*}.$OUTEXT"

if [[ "$VERBOSE" == "true" ]]; then
	echo verbose=$VERBOSE
	echo prefix=$PREFIX
	echo dir=$DIR
	echo outext=$OUTEXT
	echo params=$PARAMS
	echo nargs=$NARGS
	echo input=$INPUT
	echo filename=$FILENAME
	echo base=$BASE
	echo output=$OUTPUT
fi


/usr/bin/ffmpeg -i $INPUT $PARAMS $OUTPUT


if [ ! -f "$OUTPUT" ]; then
	echo
        echo -e "${RED}Fail!${ENDCOLOR}"
	echo "No output file: '$OUTPUT'"
else
        echo
	echo -e "${LIME}OK!${ENDCOLOR}"
	echo -e "${WHITE}$OUTPUT${ENDCOLOR}"
fi
