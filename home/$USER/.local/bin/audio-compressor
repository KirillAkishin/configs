#!/bin/bash

usage() {
    echo "Usage: $0 [OPTION]"
    echo "Convert all MP3s in a folder to compressed MP3s"
    echo "  -b bitrate    Reduce bitrate to [BITRATE] kbps (default: 64)"
    echo "  -p prefix     NEW_NAME = [PREFIX] + OLD_NAME (default: '_')"
    echo "  -d directory  If it is not empty, the script compresses it into this [DIR] (default: '')."
    echo "  -v verbose    Verbose mode (default: false)"
    echo "  -h help       Print this help message"
    echo
    exit 1
}


VERBOSE=false
BITRATE=64k
PREFIX='_'
DIR=''
NARGS=$#

while getopts "b:p:d:vh" opt; do
  case $opt in
    b)
      BITRATE=${OPTARG}k
      NARGS=$((NARGS-2))
      ;;
    p)
      PREFIX=${OPTARG}
      NARGS=$((NARGS-2))
      ;;
    d)
      DIR=${OPTARG}
      NARGS=$((NARGS-2))
      ;;
    v)
      VERBOSE=true
      NARGS=$((NARGS-1))
      ;;
    h)
      usage
      ;;
    ?)
      usage
      ;;
  esac
done

if [ $NARGS -ne 0 ]; then
    usage
    exit 1
fi


if [[ "$VERBOSE" == "true" ]]; then
  echo bitrate=$BITRATE
  echo prefix=$PREFIX
  echo dir=$DIR
  echo verbose=$VERBOSE
  echo nargs=$NARGS
  echo mode=$MODE
  echo
fi


if [[ -n "$DIR" ]]; then
  mkdir -p $DIR
  PREFIX=$DIR"/"$PREFIX
fi

count=1
for file in *.{mp3,wav}; do
  EXT="${file##*.}"
  echo EXT=$EXT
  [[ -e "$file" ]] || continue # Skip if no matches found
  ffmpeg -i "$file" -b:a $BITRATE "$PREFIX($EXT,$count)${file%.*}.mp3"
  ((count++))
done


if [[ "$MODE" -eq 1 ]]; then
  # 1) Reduce Bitrate (File Size)
  ffmpeg -i input.mp3 -b:a 64k output.mp3 #(Sets bitrate to 64 kbps)
elif [[ "$MODE" -eq 2 ]]; then
  # 2) Change Sample Rate:
  ffmpeg -i input.wav -ar 22050 output.wav #(Lowers sample rate to 22.05 kHz).
elif [[ "$MODE" -eq 3 ]]; then
  # 3) Dynamic Range Compression (Volume Leveling):
  ffmpeg -i input.mp3 -af "acompressor=threshold=-12dB:ratio=4" output.mp3
else
  echo
fi


