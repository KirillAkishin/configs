#!/bin/bash

usage() {
    echo "Usage: $0 [OPTION]"
    echo "Convert all MP3s in a folder to compressed MP3s"
    echo "  -b bitrate    Reduce bitrate to [BITRATE] kbps (default: 64)"
    echo "  -p prefix     NEW_NAME = [PREFIX] + OLD_NAME (default: '_')"
    echo "  -d directory  If it is not empty, the script compresses it into this [DIR] (default: '')."
    echo "  -v verbose    Verbose mode (default: false)"
    echo "  -h help       Print this help message"
    echo
    exit 1
}


VERBOSE=false
BITRATE=64k
PREFIX='_'
DIR=''
NARGS=$#

while getopts "b:p:d:vh" opt; do
  case $opt in
    b)
      BITRATE=${OPTARG}k
      NARGS=$((NARGS-2))
      ;;
    p)
      PREFIX=${OPTARG}
      NARGS=$((NARGS-2))
      ;;
    d)
      DIR=${OPTARG}
      NARGS=$((NARGS-2))
      ;;
    v)
      VERBOSE=true
      NARGS=$((NARGS-1))
      ;;
    h)
      usage
      ;;
    ?)
      usage
      ;;
  esac
done

if [ $NARGS -ne 0 ]; then
    usage
    exit 1
fi


if [[ "$VERBOSE" == "true" ]]; then
  echo bitrate=$BITRATE
  echo prefix=$PREFIX
  echo dir=$DIR
  echo verbose=$VERBOSE
  echo nargs=$NARGS
  echo mode=$MODE
  echo
fi


if [[ -n "$DIR" ]]; then
  mkdir -p $DIR
  PREFIX=$DIR"/"$PREFIX
fi

count=1
for file in *.{mp3,wav}; do
  [[ -e "$file" ]] || continue # Skip if no matches found
#   EXT="${file##*.}"
#   echo EXT=$EXT
#   ffmpeg -i "$file" -b:a $BITRATE "$PREFIX($EXT,$count)${file%.*}.mp3"
  ffmpeg -n -i "$file" -b:a $BITRATE "$PREFIX${file%.*}.mp3"
  ((count++))
done


# cmd='ffmpeg -i "$file" -b:a $BITRATE "$PREFIX($EXT,$count)${file%.*}.mp3"'
# echo $cmd
# $cmd

if [[ "$MODE" -eq 1 ]]; then
  # 1)
  ffmpeg -i "$file" -b:a $BITRATE "$PREFIX($EXT,$count)${file%.*}.mp3"
elif [[ "$MODE" -eq 2 ]]; then
  # 2) Reduce Bitrate (File Size). Sets bitrate to 64 kbps:
  ffmpeg -i input.mp3 -b:a 64k output.mp3
elif [[ "$MODE" -eq 3 ]]; then
  # 3) Lowers sample rate to 22.05 kHz (standard is 44.1 kHz). Change Sample Rate:
  ffmpeg -i input.wav -ar 22050 output.wav
elif [[ "$MODE" -eq 4 ]]; then
  # 4) Dynamic Range Compression (Volume Leveling):
  ffmpeg -i input.mp3 -af "acompressor=threshold=-12dB:ratio=4" output.mp3
elif [[ "$MODE" -eq 5 ]]; then
  # 5) Converts audio to a single channel (mono).
  ffmpeg -i input.mp3 -ac 1 output.mp3
elif [[ "$MODE" -eq 6 ]]; then
  # 6) Variable Bitrate (VBR). AvgBitRate (-q:a Value): ~65kbps (9), ~115kbps (6), ~245kbps (0).
  ffmpeg -i input.mp3 -codec:a libmp3lame -q:a 5 output.mp3
elif [[ "$MODE" -eq 7 ]]; then
  # 7)
  ffmpeg -i input.mp3 output.mp3
else
  echo
fi


# Strategies
# For Music: Use VBR with -q:a 4 or -q:a 5 for a good balance of size and fidelity.
# For Voice/Podcasts: Convert to mono (-ac 1) and use a bitrate between 48k and 64k.
# For Maximum Savings: Consider switching to Opus (-c:a libopus) if your playback device supports it, as it is much more efficient than MP3 at low bitrates.
